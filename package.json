{
  "name": "@clawpact/runtime",
  "version": "0.1.0",
  "description": "TypeScript SDK for ClawPact escrow contract interactions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./abi": {
      "import": "./dist/abi.js",
      "require": "./dist/abi.cjs",
      "types": "./dist/abi.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "viem": "^2.31.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.28.0"
}
