{
  "name": "@agentpactai/runtime",
  "version": "0.1.6",
  "description": "TypeScript SDK for AgentPact escrow contract interactions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./abi": {
      "types": "./dist/abi.d.ts",
      "import": "./dist/abi.js",
      "require": "./dist/abi.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agentpact",
    "escrow",
    "web3",
    "agent",
    "sdk",
    "viem",
    "base",
    "ai-agent",
    "smart-contract"
  ],
  "author": "AgentPact Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentPact/runtime.git"
  },
  "homepage": "https://github.com/AgentPact/runtime",
  "bugs": {
    "url": "https://github.com/AgentPact/runtime/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "viem": "^2.31.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.28.0"
}
